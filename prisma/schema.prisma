generator client {
  provider = "prisma-client"
  output   = "../src/generated"
}

datasource db {
  provider = "postgresql"
}

// ------------------------ enum for roles ------------------------
enum Role {
  ADMIN
  DOCTOR
  PATIENT
  HOSPITAL_MANAGER
}

// ------------------------ enum for appointment status ------------------------
enum AppointmentStatus {
  PENDING
  CONFIRMED
  DONE
  CANCELLED
}

// ------------------------ enum for otp type ------------------------
enum OtpType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
}

// ------------------------ main authentication table ------------------------
model User {
  id         String   @id @default(uuid())
  email      String?  @unique
  password   String?
  googleId   String?  @unique
  role       Role
  isVerified Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  // Relationships
  adminProfile           AdminProfile?
  doctorProfile          DoctorProfile?
  patientProfile         PatientProfile?
  hospitalManagerProfile HospitalManagerProfile?
  verifyOtp              OtpVerification[]
}

// ------------------------ admin profile (one to one with user) ------------------------
model AdminProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id])
}

// ------------------------ doctor profile ------------------------
model DoctorProfile {
  id             String  @id @default(uuid())
  userId         String  @unique
  doctorId       String  @unique
  name           String
  phone          String?
  designation    String?
  specialization String?
  user           User    @relation(fields: [userId], references: [id])

  hospitals     DoctorHospital[]
  availability  Availability[]
  appointments  Appointment[]
  prescriptions Prescription[]
}

// ------------------------ patient profile ------------------------
model PatientProfile {
  id        String  @id @default(uuid())
  userId    String  @unique
  patientId String  @unique
  name      String
  phone     String?
  user      User    @relation(fields: [userId], references: [id])

  appointments  Appointment[]
  prescriptions Prescription[]
}

// ------------------------ hospital manager profile (each manager belongs to one hospital) ------------------------
model HospitalManagerProfile {
  id         String   @id @default(uuid())
  userId     String   @unique
  employeeId String   @unique
  hospitalId String
  user       User     @relation(fields: [userId], references: [id])
  hospital   Hospital @relation(fields: [hospitalId], references: [id])
}

// ------------------------ hospital ------------------------
model Hospital {
  id        String   @id @default(uuid())
  name      String
  address   String
  city      String
  createdAt DateTime @default(now())

  doctors      DoctorHospital[]
  managers     HospitalManagerProfile[]
  appointments Appointment[]
}

// ------------------------ doctor hospital (many to many) ------------------------
// ------------------------ junction table for doctor and hospital ------------------------
model DoctorHospital {
  id         String @id @default(uuid())
  doctorId   String
  hospitalId String

  doctor   DoctorProfile @relation(fields: [doctorId], references: [id])
  hospital Hospital      @relation(fields: [hospitalId], references: [id])

  @@unique([doctorId, hospitalId]) // prevents duplicate assignments
}

// ------------------------ availability ------------------------
model Availability {
  id        String   @id @default(uuid())
  doctorId  String
  date      DateTime
  startTime String
  endTime   String

  doctor DoctorProfile @relation(fields: [doctorId], references: [id])
}

// ------------------------ appointment ------------------------
model Appointment {
  id         String            @id @default(uuid())
  patientId  String
  doctorId   String
  hospitalId String
  date       DateTime
  time       String
  status     AppointmentStatus @default(PENDING)
  createdAt  DateTime          @default(now())

  patient  PatientProfile @relation(fields: [patientId], references: [id])
  doctor   DoctorProfile  @relation(fields: [doctorId], references: [id])
  hospital Hospital       @relation(fields: [hospitalId], references: [id])

  prescription Prescription? // one appointment can have only one prescription
}

// ------------------------ prescription ------------------------
model Prescription {
  id            String   @id @default(uuid())
  appointmentId String   @unique
  patientId     String
  doctorId      String
  fileUrl       String
  createdAt     DateTime @default(now())

  appointment Appointment    @relation(fields: [appointmentId], references: [id])
  patient     PatientProfile @relation(fields: [patientId], references: [id])
  doctor      DoctorProfile  @relation(fields: [doctorId], references: [id])
}

// ------------------------ otp verification ------------------------
model OtpVerification {
  id        String   @id @default(uuid())
  userId    String
  code      String
  type      OtpType // determines the purpose of the OTP
  expiresAt DateTime
  used      Boolean  @default(false)
  attempts  Int      @default(0)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
